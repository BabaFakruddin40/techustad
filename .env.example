# ── App ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Security ──────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
SESSION_SECRET=change-this-to-another-long-random-secret

# ── Google OAuth ──────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Instagram OAuth (Meta) ────────────────────────────────────────────────
# Create at: https://developers.facebook.com → My Apps → Create App
# Add Instagram Basic Display product
# Valid OAuth Redirect URI: http://localhost:3000/auth/instagram/callback
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ── Twilio (Phone OTP via SMS) ────────────────────────────────────────────
# Create at: https://www.twilio.com/try-twilio
# NOTE: Without Twilio configured, OTP codes are printed to the server console (dev mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Stripe (Payments) ─────────────────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
# NOTE: Without Stripe configured, payments run in demo/simulation mode
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
